    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@react-aria/optimize-locales-plugin": "^1.1.5",
    "@react-spectrum/s2": "^1.2.0",
    "@react-spectrum/theme-default": "^3.5.24",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mobx": "^6.13.5",
    "mobx-react-lite": "^4.0.7",
    "morgan": "^1.10.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "^7.13.1",
    "serialport": "^12.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
