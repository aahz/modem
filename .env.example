NODE_ENV=development
PORT=8080
DB_PATH=./data/modem.sqlite
JWT_SECRET=change-me
JWT_EXPIRES_IN=12h
SERIAL_PATH=/dev/ttyACM0
MODEM_DEVICE=/dev/ttyACM0
BAUD_RATE=9600
USER_ALLOWED_COMMANDS=AT,ATI,AT+CSQ,AT+CREG?,AT+COPS?,AT+CGATT?
ADMIN_BOOTSTRAP_USERNAME=root
# Optional. If omitted, temporary password is generated on first start and shown in logs.
# ADMIN_BOOTSTRAP_PASSWORD=
